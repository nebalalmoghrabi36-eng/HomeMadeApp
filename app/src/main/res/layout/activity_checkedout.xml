<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="#F5F5F5">
    <!--  TOOLBAR  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#2E7D32"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="تأكيد الطلب"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="right"/>
        <ImageView
            android:id="@+id/btnBackCheckout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert" />

    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <!--  ملخص الطلب  -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="  ملخص الطلب 📋"
                        android:textColor="#1B1B1B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="right"
                        android:layout_marginBottom="12dp"/>
                    <!--  قائمة المنتجات  -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvOrderItems"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"/>
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"/>
                    <!--  المجموع  -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="المجموع الكلي:"
                            android:textColor="#1B1B1B"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvCheckoutTotal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=" JOD 0 "
                            android:textColor="#2E7D32"
                            android:textSize="22sp"
                            android:textStyle="bold"/>
                       ]
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  معلومات الزبون  -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=" معلومات التوصيل👤"
                        android:textColor="#1B1B1B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="right"
                        android:layout_marginBottom="12dp"/>
                    <!--  الاسم  -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="الاسم الكامل"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        android:gravity="right"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCustomerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="أدخل اسمك الكامل"
                            android:gravity="right"
                            android:inputType="textPersonName"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <!--  رقم الهاتف  -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="رقم الهاتف"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        android:gravity="right"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCustomerPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="07XXXXXXXX"
                            android:gravity="right"
                            android:inputType="phone"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <!--  العنوان  -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="العنوان"
                        android:textColor="#757575"
                        android:textSize="12sp"
                        android:gravity="right"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etCustomerAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="المدينة، الحي، الشارع"
                            android:gravity="right"
                            android:inputType="textMultiLine"
                            android:lines="2"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  طريقة الدفع  -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="طريقة الدفع 💳 "
                        android:textColor="#1B1B1B"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="right"
                        android:layout_marginBottom="12dp"/>
                    <!--  نقد  -->
                    <LinearLayout
                        android:id="@+id/layoutCash"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#E8F5E9"
                        android:layout_marginBottom="10dp"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <RadioButton
                            android:id="@+id/rbCash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="#2E7D32"
                            android:layout_marginStart="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text=" الدفع نقداً 💵 "
                                android:textColor="#1B1B1B"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="right"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="الدفع عند الاستلام"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:gravity="right"/>
                        </LinearLayout>
                    </LinearLayout>
                    <!--  بوابة دفع  -->
                    <LinearLayout
                        android:id="@+id/layoutOnlinePayment"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F5F5F5"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground">
                        <RadioButton
                            android:id="@+id/rbOnline"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:buttonTint="#2E7D32"
                            android:layout_marginStart="8dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text=" بوابة الدفع الإلكتروني 💳"
                                android:textColor="#1B1B1B"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:gravity="right"/>
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="دفع آمن عبر الإنترنت (محاكاة)"
                                android:textColor="#757575"
                                android:textSize="11sp"
                                android:gravity="right"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <!--  زر تأكيد الطلب  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="8dp">
        <Button
            android:id="@+id/btnConfirmOrder"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="  تأكيد الطلب ✅"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2E7D32"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>
</LinearLayout>