<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:id="@+id/main">
    <!--  ===== TOOLBAR ثابت فوق =====  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">
        <!--  اليمين: اسم التطبيق  -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🏠 هوم ميد | Homemade"
            android:textColor="#2E7D32"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="right"/>
        <!--  اليسار: سلة + زر دخول  -->
        <TextView
            android:id="@+id/btnCart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="22sp"
            android:layout_marginEnd="12dp"/>
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="دخول"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:backgroundTint="#1B1B1B"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>
    <!--  ===== المحتوى القابل للسكرول =====  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F5F5F5"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!--  HERO SECTION  -->
            <!--  STATS  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="#206623"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:gravity="center"
                    android:text="مرحباً بك في Homemade"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="منصة سوق مركزي للمشاريع المنزلية - اكتشف منتجات مميزة صنعت بحب من منازل عائلية"
                    android:textColor="#C8E6C9"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBrowseProducts"
                        style="@style/Widget.MaterialComponents.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:layout_marginEnd="10dp"
                        android:backgroundTint="#FFFFFF"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="تصفح المنتجات"
                        android:textColor="#2E7D32"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/btnJoinSeller"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:text="انضم كبائع"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        app:strokeColor="#FFFFFF"
                        app:strokeWidth="2dp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="horizontal"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+500"
                        android:textColor="#1B1B1B"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="طلب ناجح"
                        android:textColor="#757575"
                        android:textSize="12sp"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="50dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8"
                        android:textColor="#1B1B1B"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تقييم العملاء"
                        android:textColor="#757575"
                        android:textSize="12sp"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="50dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👥"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+50"
                        android:textColor="#1B1B1B"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بائع نشط"
                        android:textColor="#757575"
                        android:textSize="12sp"/>
                </LinearLayout>
                <View
                    android:layout_width="1dp"
                    android:layout_height="50dp"
                    android:background="#E0E0E0"
                    android:layout_gravity="center_vertical"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+8"
                        android:textColor="#1B1B1B"
                        android:textSize="22sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="منتج متوفر"
                        android:textColor="#757575"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
            <!--  CATEGORIES  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:paddingTop="20dp"
                android:paddingBottom="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="تصفح حسب الفئة"
                    android:textColor="#1B1B1B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="right"
                    android:layout_marginBottom="16dp"/>

                <!--  Row 1  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">
                    <LinearLayout
                        android:id="@+id/catFood"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍰"
                            android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="أكل وحلويات"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/catAccessories"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💍"
                            android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="إكسسوارات"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/catHandcraft"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎨"
                            android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="أشغال يدوية"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
                <!--  Row 2  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:id="@+id/catDecor"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏡"
                            android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ديكور"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/catKids"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🧸" android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="أطفال"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/catGifts"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:elevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎁"
                            android:textSize="28sp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="هدايا"
                            android:textColor="#333333"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <!--  FEATURED PRODUCTS  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingTop="20dp"
                android:paddingBottom="16dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="المنتجات المميزة"
                        android:textColor="#1B1B1B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="right"/>
                    <TextView
                        android:id="@+id/tvSeeAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" عرض الكل"
                        android:textColor="#2E7D32"
                        android:textSize="13sp"
                        android:clickable="true"
                        android:foreground="?attr/selectableItemBackground"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeaturedProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>
            </LinearLayout>
            <!--  WHY HOMEMADE  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#F5F5F5"
                android:paddingTop="20dp"
                android:paddingBottom="24dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="لماذا Homemade؟"
                    android:textColor="#1B1B1B"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="right"
                    android:layout_marginBottom="16dp"/>
                <!--  Card 1  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp"
                    android:elevation="2dp">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="⭐"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="#FFF8E1"
                        android:padding="6dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="منتجات أصيلة"
                            android:textColor="#1B1B1B"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="right"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="كل منتج صُنع يدوياً بعناية واهتمام حقيقي"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:gravity="right"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
                <!--  Card 2  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="10dp"
                    android:elevation="2dp">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🚀"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="#E8F5E9"
                        android:padding="6dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="توصيل سريع"
                            android:textColor="#1B1B1B"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="right"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="نوصلك طلبك بأسرع وقت وأمان تام"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:gravity="right"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
                <!--  Card 3  -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp"
                    android:elevation="2dp">
                    <TextView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:text="🤝"
                        android:textSize="28sp"
                        android:gravity="center"
                        android:background="#E3F2FD"
                        android:padding="6dp"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="دعم البائعين"
                            android:textColor="#1B1B1B"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:gravity="right"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="نساعد أصحاب المشاريع المنزلية على النمو"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:gravity="right"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>