<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:layoutDirection="rtl" android:background="#F5F5F5">
    <!--  TOOLBAR  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="#2E7D32" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:orientation="horizontal">
        <TextView android:id="@+id/tvProductTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="تفاصيل المنتج" android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:gravity="right"/>
        <ImageView android:id="@+id/btnBack" android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_close_clear_cancel" android:tint="#FFFFFF"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!--  صورة المنتج  -->
            <ImageView android:id="@+id/imgProductDetail" android:layout_width="match_parent" android:layout_height="250dp" android:scaleType="centerCrop" android:background="@drawable/ic_image_placeholder"/>
            <!--  معلومات المنتج  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:layout_marginTop="8dp">
                <!--  الاسم والسعر  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvDetailPrice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 ₪" android:textColor="#2E7D32" android:textSize="22sp" android:textStyle="bold"/>
                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                    <TextView android:id="@+id/tvDetailName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="اسم المنتج" android:textColor="#1B1B1B" android:textSize="20sp" android:textStyle="bold"/>
                </LinearLayout>
                <!--  الفئة  -->
                <TextView android:id="@+id/tvDetailCategory" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الفئة" android:textColor="#2E7D32" android:textSize="13sp" android:background="@drawable/tab_rounded" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_gravity="end" android:layout_marginTop="8dp"/>
                <!--  التقييم  -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_gravity="end" android:layout_marginTop="8dp">
                    <TextView android:id="@+id/tvDetailRatingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="(0)" android:textColor="#AAAAAA" android:textSize="13sp" android:layout_marginEnd="4dp"/>
                    <RatingBar android:id="@+id/ratingBarDetail" android:layout_width="wrap_content" android:layout_height="20dp" android:numStars="5" android:rating="0" android:stepSize="0.5" android:isIndicator="true" style="?android:attr/ratingBarStyleSmall"/>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginTop="12dp" android:layout_marginBottom="12dp"/>
                <!--  الوصف  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="وصف المنتج" android:textColor="#1B1B1B" android:textSize="15sp" android:textStyle="bold" android:gravity="right" android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvDetailDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="وصف المنتج" android:textColor="#555555" android:textSize="14sp" android:gravity="right" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!--  زر إضافة للسلة  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFFFFF" android:padding="16dp" android:elevation="8dp">
        <Button android:id="@+id/btnAddToCartDetail" android:layout_width="match_parent" android:layout_height="50dp" android:text="🛒 أضف للسلة" android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#2E7D32" style="@style/Widget.MaterialComponents.Button"/>
    </LinearLayout>
</LinearLayout>